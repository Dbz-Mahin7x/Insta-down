# Instagram Scraper API Configuration

# Server
PORT=3000
NODE_ENV=production

# Rate Limiting (15 minutes window)
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=50

# Cache (1 hour in seconds)
CACHE_TTL=3600

# Puppeteer (optional)
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=

# API Keys (if using paid services)
RAPIDAPI_KEY=