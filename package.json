{
  "name": "instagram-scraper-api",
  "version": "2.0.0",
  "description": "Self-hosted Instagram video scraper API with multiple fallback methods",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node scripts/test.js",
    "deploy": "bash scripts/deploy.sh",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 stop ecosystem.config.js",
    "pm2-restart": "pm2 restart ecosystem.config.js",
    "pm2-logs": "pm2 logs",
    "docker-build": "docker build -t insta-scraper-api .",
    "docker-run": "docker run -p 3000:3000 --env-file .env insta-scraper-api",
    "docker-compose": "docker-compose up -d",
    "vercel": "vercel",
    "vercel-prod": "vercel --prod"
  },
  "keywords": [
    "instagram",
    "scraper",
    "downloader",
    "api",
    "reels",
    "video",
    "nodejs",
    "express",
    "puppeteer"
  ],
  "author": {
    "name": "Mahin Ahmed",
    "url": "https://github.com/Dbz-Mahin7x"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dbz-Mahin7x/instagram-scraper-api.git"
  },
  "bugs": {
    "url": "https://github.com/Dbz-Mahin7x/instagram-scraper-api/issues"
  },
  "homepage": "https://github.com/Dbz-Mahin7x/instagram-scraper-api#readme",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "node-cache": "^5.1.2",
    "puppeteer": "^21.5.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "fs-extra": "^11.2.0",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "user-agents": "^1.0.1414"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pm2": "^5.3.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}